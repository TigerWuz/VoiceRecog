<Window x:Class="VoiceRecog.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:VoiceRecog"
        mc:Ignorable="d"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        Title="VoiceRecognition for MSFS"
        Height="550"
        Width="750"
        MinHeight="400"
        MinWidth="600"
        Icon="/MainIcon.ico"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.FontWeight="Light"
        TextElement.FontSize="14"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <Grid Background="#444040" Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- obere Leiste -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="Button1"
                    Grid.Column="0"
                    Width="70"
                    Content="Settings"
                    Click="Settings"
                    Margin="0,0,10,0" IsEnabled="False"/>

            <TextBlock Grid.Column="1"
                       Text="VoiceRecognition for MSFS"
                       FontSize="24"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

            <Button x:Name="Quit_Button"
                    Grid.Column="2"
                    Width="70"
                    Content="Quit"
                    Click="Quit_Click"/>
        </Grid>

        <!-- Untertitel -->
        <TextBlock Grid.Row="1"
                   Margin="0,10,0,10"
                   HorizontalAlignment="Center"
                   Text="Your virtual co-pilot!"
                   Foreground="White"
                   FontStyle="Italic"/>

        <!-- Logfenster -->
        <TextBox x:Name="TextBox1"
                 Grid.Row="2"
                 Margin="0,0,0,10"
                 AcceptsReturn="True"
                 IsReadOnly="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalAlignment="Stretch"
                 VerticalAlignment="Stretch"
                 Background="#E4DFDF"/>

        <!-- Statusleiste -->
        <Grid Grid.Row="3">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="SimConnect:"
                       Foreground="#D8D2D2"
                       VerticalAlignment="Center"/>

            <Ellipse x:Name="SimconnectStatus"
                     Grid.Column="1"
                     Width="12"
                     Height="12"
                     Fill="Red"
                     VerticalAlignment="Center"/>

            <TextBlock Grid.Column="3"
                       Text="Recognition:"
                       Foreground="#D8D2D2"
                       VerticalAlignment="Center"/>

            <Ellipse x:Name="RecogStatus"
                     Grid.Column="4"
                     Width="12"
                     Height="12"
                     Fill="Red"
                     VerticalAlignment="Center"/>

        </Grid>

    </Grid>

</Window>